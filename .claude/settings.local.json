{
  "permissions": {
    "allow": [
      "Bash(cargo check:*)",
      "mcp__context7__resolve-library-id",
      "mcp__context7__query-docs",
      "Bash(cargo test:*)",
      "Bash(cargo info:*)",
      "mcp__syncfusion-angular-assistant__sf_angular_component"
    ]
  },
  "enableAllProjectMcpServers": true,
  "enabledMcpjsonServers": [
    "dbhub",
    "syncfusion-blazor-assistant",
    "playwright",
    "grep",
    "context7",
    "syncfusion-angular-assistant"
  ],
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/check-no-inline-comments.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/check-file-header.sh"
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/check-syncfusion-ui.sh"
          }
        ]
      }
    ]
  }
}
