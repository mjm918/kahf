{
  "permissions": {
    "allow": [
      "Bash(cargo check:*)",
      "mcp__context7__resolve-library-id",
      "mcp__context7__query-docs",
      "Bash(cargo test:*)",
      "Bash(cargo info:*)",
      "mcp__syncfusion-angular-assistant__sf_angular_component",
      "Bash(bun:*)",
      "Bash(ng new:*)",
      "mcp__syncfusion-angular-assistant__sf_angular_assistant",
      "mcp__syncfusion-angular-assistant__sf_angular_style",
      "mcp__playwright__browser_navigate",
      "mcp__playwright__browser_take_screenshot",
      "mcp__playwright__browser_resize",
      "Bash(chmod +x:*)",
      "Bash(.claude/hooks/check-no-inline-comments.sh:*)",
      "Bash(npx ng:*)",
      "mcp__playwright__browser_type",
      "WebSearch",
      "Bash(docker:*)",
      "mcp__grep__searchGitHub",
      "WebFetch(domain:docs.rs)",
      "Bash(redis-cli KEYS:*)",
      "Bash(grep:*)",
      "mcp__syncfusion-angular-assistant__sf_angular_layout",
      "mcp__syncfusion-angular-assistant__get_angular_blocks",
      "mcp__playwright__browser_click",
      "mcp__dbhub__execute_sql",
      "Bash(psql:*)",
      "Bash(cargo build:*)",
      "WebFetch(domain:*)",
      "Bash(cargo search:*)"
    ]
  },
  "enableAllProjectMcpServers": true,
  "enabledMcpjsonServers": [
    "dbhub",
    "syncfusion-blazor-assistant",
    "playwright",
    "grep",
    "context7",
    "syncfusion-angular-assistant"
  ],
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/check-no-inline-comments.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/check-file-header.sh"
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/check-syncfusion-ui.sh"
          }
        ]
      }
    ]
  }
}
